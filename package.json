{
  "name": "chess-and-mcp-arena",
  "version": "1.0.0",
  "description": "Chess! and MCP Arena — локальные шахматы для людей и MCP-агентов.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/alexup71rus/Chess-and-MCP-Arena.git"
  },
  "homepage": "https://github.com/alexup71rus/Chess-and-MCP-Arena#readme",
  "keywords": [
    "chess",
    "mcp",
    "model-context-protocol",
    "react",
    "typescript"
  ],
  "type": "module",
  "scripts": {
    "start": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "tsc --noEmit && eslint . && prettier --check . && vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
