    "prettier": "^3.4.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.0.0"
